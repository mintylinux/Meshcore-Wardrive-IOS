	<string>MeshCore Wardrive needs background location access to continue mapping coverage while the app is in the background.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>MeshCore Wardrive uses the local network for MQTT communication with mesh network observers.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>bluetooth-central</string>
		<string>location</string>
		<string>fetch</string>
	</array>
